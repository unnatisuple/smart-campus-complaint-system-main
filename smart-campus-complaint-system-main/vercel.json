{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "client/dist",
  "public": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://your-backend-url.com/api/$1"
    }
  ],
  "env": [
    {
      "key": "VITE_API_URL",
      "value": "https://your-backend-url.com"
    }
  ]
}
