// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  passwordHash String  @map("password_hash")
  role       Role     @default(student)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  student    Student?
  staff      Staff?
  admin      Admin?
  notifications Notification[]
  activityLogs  ActivityLog[]
  complaintUpdates ComplaintUpdate[]

  @@map("users")
}

enum Role {
  student
  staff
  admin
}

model Student {
  id           String @id @default(uuid())
  userId       String @unique @map("user_id")
  enrollmentNo String @unique @map("enrollment_no")
  department   String
  year         Int
  mobile       String

  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  complaints   Complaint[]
  feedbacks    Feedback[]

  @@map("students")
}

model Staff {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  expertise      String[]
  department     String
  assignedCount  Int      @default(0) @map("assigned_count")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments    Assignment[]

  @@map("staff")
}

model Admin {
  id           String  @id @default(uuid())
  userId       String  @unique @map("user_id")
  isSuperAdmin Boolean @default(false) @map("is_super_admin")

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Department {
  id   String @id @default(uuid())
  name String @unique
  code String @unique

  @@map("departments")
}

model Category {
  id          String @id @default(uuid())
  name        String @unique
  icon        String
  description String
  color       String

  complaints  Complaint[]

  @@map("categories")
}

model Complaint {
  id            String          @id @default(uuid())
  complaintNo   String          @unique @map("complaint_no")
  studentId     String          @map("student_id")
  title         String
  description   String
  categoryId    String          @map("category_id")
  priority      Priority        @default(medium)
  status        ComplaintStatus @default(pending)
  building      String
  floor         String
  roomNumber    String          @map("room_number")
  locationNotes String?         @map("location_notes")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  resolvedAt    DateTime?       @map("resolved_at")

  student       Student         @relation(fields: [studentId], references: [id])
  category      Category        @relation(fields: [categoryId], references: [id])
  media         ComplaintMedia[]
  assignment    Assignment?
  updates       ComplaintUpdate[]
  feedback      Feedback?

  @@map("complaints")
}

enum Priority {
  low
  medium
  high
  critical
}

enum ComplaintStatus {
  pending
  assigned
  in_progress
  resolved
  closed
}

model ComplaintMedia {
  id           String @id @default(uuid())
  complaintId  String @map("complaint_id")
  url          String
  type         MediaType
  cloudinaryId String? @map("cloudinary_id")
  name         String

  complaint    Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@map("complaint_media")
}

enum MediaType {
  image
  video
  document
}

model Assignment {
  id          String   @id @default(uuid())
  complaintId String   @unique @map("complaint_id")
  staffId     String   @map("staff_id")
  assignedBy  String   @map("assigned_by")
  assignedAt  DateTime @default(now()) @map("assigned_at")
  notes       String?

  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  staff       Staff     @relation(fields: [staffId], references: [id])

  @@map("assignments")
}

model ComplaintUpdate {
  id          String          @id @default(uuid())
  complaintId String          @map("complaint_id")
  updatedById String          @map("updated_by_id")
  oldStatus   ComplaintStatus @map("old_status")
  newStatus   ComplaintStatus @map("new_status")
  remarks     String
  createdAt   DateTime        @default(now()) @map("created_at")

  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  updatedBy   User      @relation(fields: [updatedById], references: [id])

  @@map("complaint_updates")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  type        NotificationType
  title       String
  message     String
  read        Boolean          @default(false)
  complaintId String?          @map("complaint_id")
  createdAt   DateTime         @default(now()) @map("created_at")

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  complaint_submitted
  complaint_assigned
  status_updated
  complaint_resolved
  new_complaint
  feedback_received
}

model Feedback {
  id          String   @id @default(uuid())
  complaintId String   @unique @map("complaint_id")
  studentId   String   @map("student_id")
  rating      Int
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id])

  @@map("feedbacks")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}
